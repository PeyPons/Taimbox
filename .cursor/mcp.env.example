# Opcional: copia a `.cursor/mcp.env` (gitignored) solo si usas el launcher stdio:
#   scripts/mcp-selfhosted-supabase.mjs
#
# Con el MCP por HTTP en `.cursor/mcp.json` (http://localhost:8080/api/mcp)
# NO suele hacer falta este archivo: basta el túnel SSH y Restart del MCP en Cursor.
# Ver docs/05-integraciones-automatizacion.md (§ MCP) y .cursor/rules/supabase-mcp-database.mdc

# Obligatorio solo para stdio / herramientas que lean env local:
SUPABASE_SERVICE_ROLE_KEY=

# Postgres vía túnel (ej. segundo -L: localhost:54322 → remoto 5432):
# DATABASE_URL=postgresql://postgres:TU_PASSWORD@127.0.0.1:54322/postgres
DATABASE_URL=

# JWT del stack (opcional)
SUPABASE_AUTH_JWT_SECRET=

# Ruta alternativa al clon selfhosted-supabase-mcp
# SELFHOSTED_SUPABASE_MCP_PATH=
