# Copia a `.cursor/mcp.env` (no se sube a git) para el MCP self-hosted de Supabase.
# Las claves VITE_* de `.env.local` se reutilizan automáticamente para URL y anon key.

# Obligatorio para herramientas privilegiadas (execute_sql, migraciones, auth.users, storage…)
SUPABASE_SERVICE_ROLE_KEY=

# Conexión directa a Postgres (self-hosted). Ejemplo local:
# DATABASE_URL=postgresql://postgres:TU_PASSWORD@localhost:5432/postgres
# En Coolify/Docker usa el host interno alcanzable desde tu máquina, no solo el dominio público.
DATABASE_URL=

# JWT secret del stack Supabase (auth). Opcional en stdio; útil para verify_jwt_secret.
SUPABASE_AUTH_JWT_SECRET=

# Ruta alternativa al servidor MCP clonado (por defecto: %USERPROFILE%\.cursor\mcp-servers\selfhosted-supabase-mcp)
# SELFHOSTED_SUPABASE_MCP_PATH=
