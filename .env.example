# Copia a .env para desarrollo local (no commitear .env).
# Producción: mismos VITE_* en el build; STRIPE_* en supabase-pi/docker/.env y compose.

VITE_SUPABASE_URL=https://api.taimbox.com
VITE_SUPABASE_ANON_KEY=

# Stripe Checkout (Dashboard → Products → Price ID, EUR/mes)
# Stripe live USD/mes (49 USD Pro · 149 USD Business)
VITE_STRIPE_PRICE_ID_PRO=price_1TbpcpKEVG6SFdOYbJx5SSvO
VITE_STRIPE_PRICE_ID_BUSINESS=price_1TbpcqKEVG6SFdOYPXFn8sZi
