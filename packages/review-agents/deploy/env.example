# Copiar a /etc/review-agent/env en ia-srv (chmod 600)

SUPABASE_URL=https://tu-supabase.example.com
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

REDIS_URL=redis://127.0.0.1:6379

# Ollama en ia-srv (solo API HTTP; no hace falta desplegar worker allí)
OLLAMA_URL=http://88.30.74.159/ollama-api
OLLAMA_API_TOKEN=
# Fallback si MAP/REDUCE no están definidos
OLLAMA_MODEL=qwen2.5:7b-instruct
# Map = análisis por fragmento (rápido); Reduce = informe final (calidad ES)
OLLAMA_MODEL_MAP=llama3.2:3b
OLLAMA_MODEL_REDUCE=qwen2.5:7b-instruct

RESEND_API_KEY=
RESEND_FROM_EMAIL=Taimbox <noreply@send.taimbox.com>

REVIEW_API_PORT=3001
REVIEW_PORTAL_URL=https://review.tudominio.com
REVIEW_CORS_ORIGIN=https://review.tudominio.com

WORKER_CONCURRENCY=1
