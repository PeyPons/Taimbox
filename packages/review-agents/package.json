{
  "name": "@taimbox/review-agents",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "shared",
    "api",
    "worker",
    "portal"
  ],
  "scripts": {
    "build": "npm run build -w @taimbox/review-shared && npm run build -w @taimbox/review-api && npm run build -w @taimbox/review-worker && npm run build -w @taimbox/review-portal",
    "dev:api": "npm run dev -w @taimbox/review-api",
    "dev:worker": "npm run dev -w @taimbox/review-worker",
    "dev:portal": "npm run dev -w @taimbox/review-portal",
    "start:api": "npm run start -w @taimbox/review-api",
    "start:worker": "npm run start -w @taimbox/review-worker"
  }
}
